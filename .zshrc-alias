#!/bin/zsh
alias sudo="sudo "
alias doas="sudo "
alias vim="nvim"
alias vi="nvim"
alias cl="clear"
alias ls="ls --color=auto"
alias l="ls -lAh"
alias la="ls -lah"
alias ll="ls -lh"
alias lq="ls -A --quoting-style=shell-always"
alias rm="rm -i"
alias mv="mv -i"
alias cp="cp -i"
alias :q="exit"
alias luamake=/tmp/lua-language-server/3rd/luamake/luamake
